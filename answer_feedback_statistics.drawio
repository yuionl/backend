        <mxCell id="phase3_title" value="阶段3: 扇形图数据结构与计算公式" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;color=#F57C00;" parent="1" vertex="1">
