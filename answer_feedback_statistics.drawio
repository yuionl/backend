          <mxGeometry x="950" y="340" width="100" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="step2_records" value="查询本题所有答题记录&#xa;AnswerRecord.objects.&#xa;filter(task=task, question=q)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;" parent="1" vertex="1">
          <mxGeometry x="60" y="420" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="step2_answered" value="计算已参与人数&#xa;answered_count = records.count()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;" parent="1" vertex="1">
          <mxGeometry x="280" y="420" width="160" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="step2_not_part" value="计算未参与人数&#xa;not_participated = total - answered" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;" parent="1" vertex="1">
          <mxGeometry x="480" y="420" width="170" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="step2_correct" value="计算正确人数&#xa;correct_count = records.&#xa;filter(is_correct=True).count()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;" parent="1" vertex="1">
          <mxGeometry x="690" y="420" width="160" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="step2_options" value="统计各选项分布&#xa;(A/B/C/D选择人数)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;" parent="1" vertex="1">
          <mxGeometry x="890" y="420" width="160" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="step2_accuracy" value="计算正确率&#xa;accuracy = correct/answered*100" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;" parent="1" vertex="1">
          <mxGeometry x="60" y="510" width="160" height="50" as="geometry"/>
        </mxCell>

