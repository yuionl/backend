          <mxGeometry x="520" y="650" width="100" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="formula1" value="应参与人数 = COUNT(CourseStudent WHERE course_id = task.course_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="520" y="680" width="610" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="formula2" value="已参与人数 = COUNT(AnswerRecord WHERE task_id = task.id AND question_id = q.id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="520" y="720" width="610" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="formula3" value="未参与人数 = 应参与人数 - 已参与人数" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="520" y="760" width="610" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="formula4" value="正确人数 = COUNT(AnswerRecord WHERE task_id = task.id AND question_id = q.id AND is_correct = True)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="520" y="800" width="610" height="30" as="geometry"/>
